# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# VS Code
.vscode

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Node Modules
node_modules/
app/frontend/node_modules/
app/backend/node_modules/


# Next.js cache
app/frontend/.next/
app/frontend/.next/dev/
app/frontend/.next/dev/cache/
app/frontend/.next/dev/cache/*
